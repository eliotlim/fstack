#!/usr/bin/env bash
# fstack-cluster: derive inferred subprofiles from observed behavior.
#
# Behavior comes first. Observations roll up into sessions (repo + branch + date).
# Each session is projected onto two axes:
#   rigor    = avg of (1 - risk_tolerance), test_rigor, architecture_care
#   appetite = avg of bias_for_action, scope_appetite
# Both fall back to 0.5 when no relevant dimension was observed.
#
# Each axis is binned into low / mid / high. 3 x 3 = 9 cells. Cells with
# >= threshold sessions become inferred subprofiles. Cluster key is
# "<rigor_bin>-<appetite_bin>" (e.g. "rigorous-steady"). Label aliases below.
#
# Context (repo, hour_band) is descriptive, not a clustering axis. It feeds
# context_distribution: a count of {<repo> @ <band>: count} used at match time.
#
# Usage:
#   fstack-cluster cluster [--threshold N] [--max-age-days N]
#   fstack-cluster match [--repo R] [--hour H]
#   fstack-cluster status

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do _self="$(readlink "$_self")"; done
BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
CONFIG="$BIN_DIR/fstack-config"

FSTACK_DIR="${FSTACK_HOME:-$HOME/.fstack}"
SESSIONS="$FSTACK_DIR/observations/sessions.jsonl"

command -v jq >/dev/null 2>&1 || { echo "fstack-cluster: jq is required" >&2; exit 1; }
"$CONFIG" exists || { echo "fstack-cluster: not initialized" >&2; exit 1; }
"$CONFIG" migrate >/dev/null 2>&1 || true
CONFIG_FILE="$("$CONFIG" path)"

_atomic_write() {
  local path="$1" content="$2"
  local tmp; tmp="$(mktemp "${path}.XXXXXX")"
  printf '%s\n' "$content" > "$tmp"
  mv "$tmp" "$path"
}

_band() {
  local h="${1:-12}"
  awk -v h="$h" 'BEGIN {
    if (h < 6 || h >= 22) print "late-night"
    else if (h < 12) print "morning"
    else if (h < 18) print "afternoon"
    else print "evening"
  }'
}

cmd="${1:-cluster}"
shift || true

case "$cmd" in
  cluster)
    threshold=3       # minimum observation count per cluster
    max_age_days=60
    while [ $# -gt 0 ]; do
      case "$1" in
        --threshold) threshold="$2"; shift 2;;
        --max-age-days) max_age_days="$2"; shift 2;;
        *) shift;;
      esac
    done
    [ -f "$SESSIONS" ] || { echo "no observations yet"; exit 0; }

    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    cutoff_epoch=$(( $(date +%s) - max_age_days * 86400 ))
    cutoff_ts="$(date -u -r "$cutoff_epoch" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d "@$cutoff_epoch" +%Y-%m-%dT%H:%M:%SZ)"

    clusters="$(jq -s --argjson th "$threshold" --arg cutoff "$cutoff_ts" --arg now "$now" '
      def band:
        if . == null then "unknown"
        elif (. < 6 or . >= 22) then "late-night"
        elif . < 12 then "morning"
        elif . < 18 then "afternoon"
        else "evening" end;
      def dbin: if . < 0.4 then "fluid" elif . < 0.65 then "balanced" else "deliberate" end;
      def abin: if . < 0.4 then "focused" elif . < 0.65 then "balanced" else "ambitious" end;
      def branch_norm:
        if . == null or . == "" then "?"
        elif (. == "main" or . == "master" or . == "develop" or . == "trunk") then "main"
        elif test("^(spike|exp|experiment)[/-]") then "spike"
        elif test("^(feature|feat)[/-]") then "feature"
        elif test("^(fix|bugfix|hotfix)[/-]") then "fix"
        elif test("^(release|rc)[/-]") then "release"
        elif test("^(chore|refactor)[/-]") then "chore"
        else "other" end;
      def archetype_for(bin_key):
        {"fluid-focused":"exploration",
         "fluid-balanced":"iteration",
         "fluid-ambitious":"sprint",
         "balanced-focused":"polish",
         "balanced-balanced":"shipping",
         "balanced-ambitious":"expansion",
         "deliberate-focused":"maintenance",
         "deliberate-balanced":"production",
         "deliberate-ambitious":"hardening"}[bin_key] // bin_key;

      # 1) Filter, drop annotate-only entries
      map(select(.ts >= $cutoff and .dimension != null))

      # 2) Aggregate per work-context = (repo, branch_norm)
      | map(. + {
          _repo: (.context.repo // "unknown"),
          _branch_norm: (.context.branch | branch_norm)
        })
      | map(. + {_skey: (._repo + ":" + ._branch_norm)})
      | group_by(._skey)
      | map(
          {
            skey: .[0]._skey,
            repo: .[0]._repo,
            branch_norm: .[0]._branch_norm,
            sample_count: length,
            last_ts: (max_by(.ts) | .ts),
            dims: (
              group_by(.dimension)
              | map({key: .[0].dimension, value: ((map(.signal * .weight) | add) / (map(.weight) | add))})
              | from_entries
            ),
            hour_counts: (
              map(.context.hour // 12) | map(tostring)
              | group_by(.) | map({key: .[0], value: length})
              | from_entries
            ),
            annotations: (
              map(.annotation // empty)
              | map(select(. != null and . != ""))
              | unique
            )
          }
        )

      # 3) Project each context to (discipline, ambition); 0.5 fallback if no relevant dim
      | map(. + {
          discipline: (
            [
              (if (.dims | has("risk_tolerance")) then (1 - .dims.risk_tolerance) else null end),
              .dims.test_rigor,
              .dims.architecture_care
            ] | map(select(. != null))
            | if length == 0 then 0.5 else (add / length) end
          ),
          ambition: (
            [.dims.bias_for_action, .dims.scope_appetite]
            | map(select(. != null))
            | if length == 0 then 0.5 else (add / length) end
          )
        })
      | map(. + {bin_key: ((.discipline | dbin) + "-" + (.ambition | abin))})
      | map(. + {archetype: (archetype_for(.bin_key))})

      # 4) Group contexts by 2-D cell, emit clusters keyed by archetype
      | group_by(.archetype)
      | map(
          {
            archetype: .[0].archetype,
            bin_key: .[0].bin_key,
            discipline_bin: (.[0].bin_key | split("-")[0]),
            ambition_bin: (.[0].bin_key | split("-")[1]),
            context_count: length,
            observation_count: (map(.sample_count) | add),
            last_seen: (max_by(.last_ts) | .last_ts),
            dimensions: (
              [.[] | .dims | to_entries[]]
              | group_by(.key)
              | map({key: .[0].key, value: ((map(.value) | add) / length)})
              | from_entries
              | ({risk_tolerance: null, bias_for_action: null, scope_appetite: null, test_rigor: null, architecture_care: null, detail_preference: null, autonomy: null}) + .
            ),
            discipline_mean: ([.[] | .discipline] | add / length),
            ambition_mean: ([.[] | .ambition] | add / length),
            context_distribution: (
              [.[] |
                .repo as $r | .branch_norm as $b |
                .hour_counts | to_entries[] |
                {key: ($r + ":" + $b + " @ " + ((.key | tonumber) | band)), count: .value}
              ]
              | group_by(.key)
              | map({key: .[0].key, value: (map(.count) | add)})
              | from_entries
            ),
            examples: (
              [.[] | .annotations[]] | unique | .[0:5]
            )
          }
        )
      | map(select(.observation_count >= $th))
    ' "$SESSIONS")"

    # Apply clusters into config: keyed by archetype. Manual subprofiles preserved.
    # A manual subprofile that happens to share an archetype name takes precedence
    # (clustering skips it, prints a notice).
    new="$(jq --argjson clusters "$clusters" --arg now "$now" '
      def context_summary($cd):
        ($cd | to_entries | sort_by(-.value))
        | if length == 0 then "no context data"
          else
            (.[0:3] | map("\(.key) (\(.value))") | join(", "))
            + (if length > 3 then ", +\(length - 3) more" else "" end)
          end;
      def merge_inferred($c; $now):
        {
          label: ($c.archetype),
          description: ($c.discipline_bin + " x " + $c.ambition_bin + ". Seen in: " + context_summary($c.context_distribution)),
          origin: "inferred",
          developer: ($c.dimensions),
          preferences: (.preferences // {code_style:null, comment_level:null, abstraction:null, error_handling:null, type_safety:null}),
          stack: (.stack // {language:[], runtime:[], frontend:[], ui:[], backend_framework:[], database:[], orm:[], auth:[], deploy:[], testing:[], declared_at:null}),
          inferred: {
            sample_count: $c.observation_count,
            rolling: $c.dimensions,
            last_observation_at: $c.last_seen
          },
          examples: $c.examples,
          context_distribution: $c.context_distribution,
          cluster_meta: {
            method: "behavior-2d-v3",
            archetype: $c.archetype,
            bin_key: $c.bin_key,
            discipline_bin: $c.discipline_bin,
            ambition_bin: $c.ambition_bin,
            discipline_mean: $c.discipline_mean,
            ambition_mean: $c.ambition_mean,
            context_count: $c.context_count,
            observation_count: $c.observation_count,
            last_clustered_at: $now
          },
          declared_at: null,
          created_at: (.created_at // $now),
          last_used_at: (.last_used_at // null)
        };

      # Step A: drop stale inferred entries (not in new clusters)
      ($clusters | map(.archetype)) as $keep
      | .profile.subprofiles |= with_entries(
          select(.value.origin == "manual" or (.key as $k | $keep | index($k)))
        )
      # Step B: upsert each cluster keyed by archetype; skip if manual collision
      | .profile.last_cluster_at = $now
      | reduce $clusters[] as $c (
          .;
          if (.profile.subprofiles[$c.archetype].origin // "inferred") == "manual"
          then .
          else .profile.subprofiles[$c.archetype] = ((.profile.subprofiles[$c.archetype] // {}) | merge_inferred($c; $now))
          end
        )
    ' "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"

    # Warn on manual collisions
    skipped="$(jq -r --argjson clusters "$clusters" '
      ($clusters | map(.archetype)) as $names
      | [.profile.subprofiles | to_entries[] | select(.value.origin == "manual" and (.key as $k | $names | index($k))) | .key]
      | join(", ")
    ' "$CONFIG_FILE")"
    [ -n "$skipped" ] && echo "skipped (manual collision): $skipped"

    n_inferred="$(jq -r '[.profile.subprofiles[] | select(.origin == "inferred")] | length' "$CONFIG_FILE")"
    n_manual="$(jq -r '[.profile.subprofiles[] | select(.origin == "manual")] | length' "$CONFIG_FILE")"
    n_obs="$(jq -r --argjson clusters "$clusters" '$clusters | map(.observation_count) | add // 0' <<<"{}")"
    echo "clustered: $n_inferred inferred archetypes (from $n_obs observations), $n_manual manual"
    ;;

  match)
    repo=""; hour=""; branch=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --repo) repo="$2"; shift 2;;
        --hour) hour="$2"; shift 2;;
        --branch) branch="$2"; shift 2;;
        *) shift;;
      esac
    done
    [ -z "$hour" ] && hour="$(date +%-H)"
    if [ -z "$repo" ]; then
      repo="$(git rev-parse --show-toplevel 2>/dev/null | tr -d '\n' | awk -F/ '{print $NF}')"
      [ -z "$repo" ] && repo="unknown"
    fi
    [ -z "$branch" ] && branch="$(git branch --show-current 2>/dev/null || echo "")"
    band="$(_band "$hour")"

    # Mirror branch_norm logic
    case "$branch" in
      ""|"?") branch_norm="?";;
      main|master|develop|trunk) branch_norm="main";;
      spike[-/]*|exp[-/]*|experiment[-/]*) branch_norm="spike";;
      feature[-/]*|feat[-/]*) branch_norm="feature";;
      fix[-/]*|bugfix[-/]*|hotfix[-/]*) branch_norm="fix";;
      release[-/]*|rc[-/]*) branch_norm="release";;
      chore[-/]*|refactor[-/]*) branch_norm="chore";;
      *) branch_norm="other";;
    esac

    exact_key="$repo:$branch_norm @ $band"
    repo_only_prefix="$repo:"

    # Tiered match:
    # 1. Exact (repo, branch_norm, band)
    # 2. Any band, same (repo, branch_norm)
    # 3. Any (repo, ?) — same repo, any branch/band
    # Tiebreaker: total observation_count.
    jq -r --arg exact "$exact_key" --arg rprefix "$repo_only_prefix" --arg rb "$repo:$branch_norm" '
      def score($sp):
        ($sp.context_distribution // {}) as $cd
        | {
            exact: ($cd[$exact] // 0),
            same_rb: ([$cd | to_entries[] | select(.key | startswith($rb + " @ ")) | .value] | add // 0),
            same_repo: ([$cd | to_entries[] | select(.key | startswith($rprefix)) | .value] | add // 0),
            observations: ($sp.cluster_meta.observation_count // 0)
          };
      [.profile.subprofiles | to_entries[]
        | select(.value.origin == "inferred")
        | (score(.value)) as $s
        | {key: .key, exact: $s.exact, same_rb: $s.same_rb, same_repo: $s.same_repo, observations: $s.observations}
      ]
      | sort_by(-.exact, -.same_rb, -.same_repo, -.observations)
      | (first // {})
      | if ((.exact // 0) > 0 or (.same_rb // 0) > 0 or (.same_repo // 0) > 0)
        then .key
        else empty end
    ' "$CONFIG_FILE"
    ;;

  status)
    last="$(jq -r '.profile.last_cluster_at // "never"' "$CONFIG_FILE")"
    pinned="$(jq -r '.profile.pinned // "none"' "$CONFIG_FILE")"
    auto="$(jq -r '.profile.auto_switch' "$CONFIG_FILE")"
    n_inf="$(jq -r '[.profile.subprofiles[] | select(.origin == "inferred")] | length' "$CONFIG_FILE")"
    n_man="$(jq -r '[.profile.subprofiles[] | select(.origin == "manual")] | length' "$CONFIG_FILE")"
    n_obs=0
    [ -f "$SESSIONS" ] && n_obs="$(wc -l < "$SESSIONS" | tr -d ' ')"
    echo "auto_switch: $auto"
    echo "pinned: $pinned"
    echo "last_cluster_at: $last"
    echo "observations: $n_obs"
    echo "inferred: $n_inf"
    echo "manual: $n_man"
    ;;

  *)
    echo "fstack-cluster: unknown command '$cmd'" >&2
    exit 2
    ;;
esac
