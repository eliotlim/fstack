#!/usr/bin/env bash
# fstack-observe: log signals per active subprofile
#
# Each observation is one JSON line in ~/.fstack/observations/<active>.jsonl:
#   {"ts":"...","skill":"...","dimension":"...","signal":0..1,"weight":1,"context":"..."}
#
# Usage:
#   fstack-observe log <dim> <signal> [--weight N] [--skill X] [--context T]
#   fstack-observe rollup [--profile <key>]
#   fstack-observe show [--limit N] [--profile <key>]
#   fstack-observe gap [--profile <key>]
#
# Dimensions: risk_tolerance, bias_for_action, scope_appetite, test_rigor, architecture_care.
# Signal 0..1 where 0 = low (cautious / deliberate / lean), 1 = high.

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do _self="$(readlink "$_self")"; done
BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
CONFIG="$BIN_DIR/fstack-config"

FSTACK_DIR="${FSTACK_HOME:-$HOME/.fstack}"
LOG_DIR="$FSTACK_DIR/observations"

command -v jq >/dev/null 2>&1 || { echo "fstack-observe: jq is required" >&2; exit 1; }
"$CONFIG" exists || { echo "fstack-observe: not initialized" >&2; exit 1; }
"$CONFIG" migrate >/dev/null 2>&1 || true

CONFIG_FILE="$("$CONFIG" path)"

_resolve_key() {
  local k="${1:-}"
  if [ -z "$k" ]; then jq -r '.profile.active' "$CONFIG_FILE"; else echo "$k"; fi
}

_log_path() {
  local k="$1"
  echo "$LOG_DIR/$k.jsonl"
}

_atomic_write() {
  local path="$1" content="$2"
  local tmp; tmp="$(mktemp "${path}.XXXXXX")"
  printf '%s\n' "$content" > "$tmp"
  mv "$tmp" "$path"
}

cmd="${1:-}"
shift || true

case "$cmd" in
  log)
    dim="${1:-}"; signal="${2:-}"; shift 2 || true
    [ -z "$dim" ] || [ -z "$signal" ] && { echo "usage: fstack-observe log <dim> <signal> [--weight N] [--skill X] [--context T]" >&2; exit 2; }
    weight=1; skill=""; context=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --weight) weight="$2"; shift 2;;
        --skill) skill="$2"; shift 2;;
        --context) context="$2"; shift 2;;
        *) shift;;
      esac
    done
    active="$(_resolve_key)"
    mkdir -p "$LOG_DIR"
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -nc \
      --arg ts "$ts" --arg skill "$skill" --arg dim "$dim" \
      --arg context "$context" --arg profile "$active" \
      --argjson signal "$signal" --argjson weight "$weight" \
      '{ts:$ts, profile:$profile, skill:$skill, dimension:$dim, signal:$signal, weight:$weight, context:$context}' \
      >> "$(_log_path "$active")"
    ;;

  rollup)
    profile=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --profile) profile="$2"; shift 2;;
        *) shift;;
      esac
    done
    key="$(_resolve_key "$profile")"
    log="$(_log_path "$key")"
    [ -f "$log" ] || { echo "no observations for $key"; exit 0; }
    rolling="$(jq -s '
      group_by(.dimension)
      | map({
          key: .[0].dimension,
          value: ((map(.signal * .weight) | add) / (map(.weight) | add))
        })
      | from_entries
    ' "$log")"
    sample_count="$(wc -l < "$log" | tr -d ' ')"
    last_ts="$(tail -1 "$log" | jq -r '.ts')"
    new="$(jq --arg k "$key" --argjson rolling "$rolling" --argjson count "$sample_count" --arg last "$last_ts" \
      '.profile.subprofiles[$k].inferred.rolling = $rolling
       | .profile.subprofiles[$k].inferred.sample_count = $count
       | .profile.subprofiles[$k].inferred.last_observation_at = $last' \
      "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"
    echo "[$key] rolled up $sample_count observations across $(jq -r 'keys | length' <<<"$rolling") dimensions"
    ;;

  show)
    profile=""; limit=20
    while [ $# -gt 0 ]; do
      case "$1" in
        --profile) profile="$2"; shift 2;;
        --limit) limit="$2"; shift 2;;
        *) shift;;
      esac
    done
    key="$(_resolve_key "$profile")"
    log="$(_log_path "$key")"
    [ -f "$log" ] || { echo "no observations for $key"; exit 0; }
    tail -n "$limit" "$log" | jq -r '"\(.ts)  \(.skill // "?")  \(.dimension)=\(.signal)  \(.context // "")"'
    ;;

  gap)
    profile=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --profile) profile="$2"; shift 2;;
        *) shift;;
      esac
    done
    key="$(_resolve_key "$profile")"
    jq -r --arg k "$key" '
      .profile.subprofiles[$k] as $sp
      | $sp.developer as $d
      | ($sp.inferred.rolling // {}) as $r
      | [
          ["risk_tolerance",     $d.risk_tolerance,     $r.risk_tolerance],
          ["bias_for_action",    $d.bias_for_action,    $r.bias_for_action],
          ["scope_appetite",     $d.scope_appetite,     $r.scope_appetite],
          ["test_rigor",         $d.test_rigor,         $r.test_rigor],
          ["architecture_care",  $d.architecture_care,  $r.architecture_care]
        ]
      | .[]
      | select(.[1] != null and .[2] != null)
      | "\(.[0]): declared=\(.[1]) observed=\(.[2]) gap=\(((.[1] - .[2]) * 100 | floor) / 100 | tostring)"
    ' "$CONFIG_FILE"
    ;;

  ""|help|-h|--help)
    sed -n '2,15p' "$0"
    ;;

  *)
    echo "fstack-observe: unknown command '$cmd'" >&2
    exit 2
    ;;
esac
