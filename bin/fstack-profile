#!/usr/bin/env bash
# fstack-profile: inspect and manage subprofiles
#
# Usage:
#   fstack-profile show [<key>]
#   fstack-profile json [<key>]
#   fstack-profile vibe [<key>]
#   fstack-profile dimensions [<key>]
#   fstack-profile stack [<key>]
#   fstack-profile list
#   fstack-profile calibrate <skill> [<key>]   # print dim values for skill
#   fstack-profile use <key>
#   fstack-profile create <key> [--label X] [--description Y] [--clone-from Z]
#   fstack-profile rename <old> <new>
#   fstack-profile remove <key>
#   fstack-profile pin [<key>]
#   fstack-profile unpin
#   fstack-profile active

set -euo pipefail

_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do _self="$(readlink "$_self")"; done
BIN_DIR="$(cd "$(dirname "$_self")" && pwd)"
CONFIG="$BIN_DIR/fstack-config"

"$CONFIG" exists || { echo "fstack-profile: not initialized. run /fstack to set up" >&2; exit 1; }
"$CONFIG" migrate >/dev/null 2>&1 || true
CONFIG_FILE="$("$CONFIG" path)"

_atomic_write() {
  local path="$1" content="$2"
  local tmp; tmp="$(mktemp "${path}.XXXXXX")"
  printf '%s\n' "$content" > "$tmp"
  mv "$tmp" "$path"
}

# Per-dim band labels (low | mid | high). New v0.6 endpoint labels.
_band_label() {
  local dim="$1" v="$2"
  if [ -z "$v" ] || [ "$v" = "null" ]; then echo "unset"; return; fi
  local b
  b="$(awk -v v="$v" 'BEGIN { if (v < 0.35) print "low"; else if (v < 0.65) print "mid"; else print "high" }')"
  case "$dim" in
    risk_tolerance)    case "$b" in low) echo "stability";; mid) echo "balanced";; high) echo "speed";; esac;;
    bias_for_action)   case "$b" in low) echo "deliberate";; mid) echo "balanced";; high) echo "action";; esac;;
    scope_appetite)    case "$b" in low) echo "focused";; mid) echo "balanced";; high) echo "ambitious";; esac;;
    test_rigor)        case "$b" in low) echo "lean";; mid) echo "balanced";; high) echo "rigorous";; esac;;
    architecture_care) case "$b" in low) echo "pragmatic";; mid) echo "balanced";; high) echo "principled";; esac;;
    detail_preference) case "$b" in low) echo "detail-oriented";; mid) echo "balanced";; high) echo "big-picture";; esac;;
    autonomy)          case "$b" in low) echo "seek-permission";; mid) echo "balanced";; high) echo "ask-forgiveness";; esac;;
    *) echo "$b";;
  esac
}

_resolve_key() {
  local k="${1:-}"
  if [ -z "$k" ]; then
    jq -r '.profile.active' "$CONFIG_FILE"
  else
    echo "$k"
  fi
}

_assert_exists() {
  local k="$1"
  local has
  has="$(jq -r --arg k "$k" '.profile.subprofiles | has($k)' "$CONFIG_FILE")"
  [ "$has" = "true" ] || { echo "fstack-profile: no subprofile '$k'" >&2; exit 1; }
}

# Dims a skill cares about, in display order. All 7 are load-bearing somewhere.
_skill_dims() {
  case "$1" in
    api)      echo "risk_tolerance architecture_care test_rigor detail_preference autonomy";;
    schema)   echo "architecture_care scope_appetite risk_tolerance test_rigor detail_preference autonomy";;
    scaffold) echo "scope_appetite test_rigor architecture_care bias_for_action risk_tolerance detail_preference autonomy";;
    stack)    echo "bias_for_action architecture_care risk_tolerance detail_preference autonomy";;
    skill)    echo "detail_preference autonomy";;
    *)        echo "risk_tolerance bias_for_action scope_appetite test_rigor architecture_care detail_preference autonomy";;
  esac
}

cmd="${1:-show}"
shift || true

case "$cmd" in
  active)
    jq -r '.profile.active' "$CONFIG_FILE"
    ;;

  list)
    jq -r '
      def short_ctx($cd):
        ($cd | to_entries | sort_by(-.value))
        | if length == 0 then ""
          else (.[0:2] | map(.key | split(" @ ")[0]) | unique | join(", "))
          end;
      .profile.active as $a
      | .profile.pinned as $pin
      | .profile.subprofiles
      | to_entries
      | sort_by(.value.origin)
      | .[]
      | (if .key == $a then "* " else "  " end)
        + "\(.key)"
        + (if .value.origin == "inferred" then " (inferred" else " (manual" end)
        + (if .key == $a then ", active" else "" end)
        + (if .key == $pin then ", pinned" else "" end)
        + ")"
        + (if .value.cluster_meta then
             "  " + .value.cluster_meta.discipline_bin + " x " + .value.cluster_meta.ambition_bin
           else "" end)
        + (if (.value.context_distribution // {}) | length > 0 then
             "  on " + short_ctx(.value.context_distribution)
           elif .value.description then ": \(.value.description)"
           else "" end)
    ' "$CONFIG_FILE"
    ;;

  pin)
    key="${1:-}"
    if [ -z "$key" ]; then
      key="$(jq -r '.profile.active' "$CONFIG_FILE")"
    fi
    _assert_exists "$key"
    new="$(jq --arg k "$key" '.profile.pinned = $k' "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"
    echo "pinned: $key (auto-suggest disabled while pinned)"
    ;;

  unpin)
    new="$(jq '.profile.pinned = null' "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"
    echo "unpinned"
    ;;

  cluster) "$BIN_DIR/fstack-cluster" cluster "$@" ;;
  match)   "$BIN_DIR/fstack-cluster" match "$@" ;;
  status)  "$BIN_DIR/fstack-cluster" status ;;

  use)
    key="${1:-}"; [ -z "$key" ] && { echo "usage: fstack-profile use <key>" >&2; exit 2; }
    _assert_exists "$key"
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    new="$(jq --arg k "$key" --arg now "$now" \
      '.profile.active = $k
       | .profile.subprofiles[$k].last_used_at = $now' "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"
    echo "active: $key"
    ;;

  create)
    key="${1:-}"; shift || true
    [ -z "$key" ] && { echo "usage: fstack-profile create <key> [--label X] [--description Y] [--clone-from Z]" >&2; exit 2; }
    [[ "$key" =~ ^[a-z0-9][a-z0-9-]*$ ]] || { echo "fstack-profile: key must be lowercase alphanumeric + dash" >&2; exit 1; }
    has="$(jq -r --arg k "$key" '.profile.subprofiles | has($k)' "$CONFIG_FILE")"
    [ "$has" = "true" ] && { echo "fstack-profile: '$key' already exists" >&2; exit 1; }
    label="$key"; desc=""; clone=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --label) label="$2"; shift 2;;
        --description) desc="$2"; shift 2;;
        --clone-from) clone="$2"; shift 2;;
        *) shift;;
      esac
    done
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    if [ -n "$clone" ]; then
      _assert_exists "$clone"
      new="$(jq --arg k "$key" --arg src "$clone" --arg lbl "$label" --arg desc "$desc" --arg now "$now" \
        '.profile.subprofiles[$k] = (.profile.subprofiles[$src]
            | .label = $lbl
            | .description = (if $desc == "" then null else $desc end)
            | .created_at = $now
            | .last_used_at = $now
            | .inferred = {sample_count:0, rolling:{}, last_observation_at:null}
            | .declared_at = null)' \
        "$CONFIG_FILE")"
    else
      new="$(jq --arg k "$key" --arg lbl "$label" --arg desc "$desc" --arg now "$now" \
        '.profile.subprofiles[$k] = {
            label: $lbl,
            description: (if $desc == "" then null else $desc end),
            origin: "manual",
            developer: {risk_tolerance:null, bias_for_action:null, scope_appetite:null, test_rigor:null, architecture_care:null, detail_preference:null, autonomy:null},
            preferences: {code_style:null, comment_level:null, abstraction:null, error_handling:null, type_safety:null},
            stack: {language:[], runtime:[], frontend:[], ui:[], backend_framework:[], database:[], orm:[], auth:[], deploy:[], testing:[], declared_at:null},
            inferred: {sample_count:0, rolling:{}, last_observation_at:null},
            examples: [],
            context_distribution: {},
            cluster_meta: null,
            declared_at: null,
            created_at: $now,
            last_used_at: null
         }' \
        "$CONFIG_FILE")"
    fi
    _atomic_write "$CONFIG_FILE" "$new"
    echo "created: $key${clone:+ (cloned from $clone)}"
    ;;

  rename)
    old="${1:-}"; new="${2:-}"
    [ -z "$old" ] || [ -z "$new" ] && { echo "usage: fstack-profile rename <old> <new>" >&2; exit 2; }
    _assert_exists "$old"
    [[ "$new" =~ ^[a-z0-9][a-z0-9-]*$ ]] || { echo "fstack-profile: new key must be lowercase alphanumeric + dash" >&2; exit 1; }
    has_new="$(jq -r --arg k "$new" '.profile.subprofiles | has($k)' "$CONFIG_FILE")"
    [ "$has_new" = "true" ] && { echo "fstack-profile: '$new' already exists" >&2; exit 1; }
    updated="$(jq --arg old "$old" --arg new "$new" \
      '.profile.subprofiles[$new] = .profile.subprofiles[$old]
       | del(.profile.subprofiles[$old])
       | if .profile.active == $old then .profile.active = $new else . end' \
      "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$updated"
    echo "renamed: $old -> $new"
    ;;

  remove)
    key="${1:-}"; [ -z "$key" ] && { echo "usage: fstack-profile remove <key>" >&2; exit 2; }
    _assert_exists "$key"
    count="$(jq -r '.profile.subprofiles | length' "$CONFIG_FILE")"
    [ "$count" -le 1 ] && { echo "fstack-profile: cannot remove the last subprofile" >&2; exit 1; }
    active="$(jq -r '.profile.active' "$CONFIG_FILE")"
    new="$(jq --arg k "$key" \
      'del(.profile.subprofiles[$k])
       | if .profile.active == $k then .profile.active = (.profile.subprofiles | keys[0]) else . end' \
      "$CONFIG_FILE")"
    _atomic_write "$CONFIG_FILE" "$new"
    [ "$active" = "$key" ] && echo "removed: $key (active switched to $(jq -r '.profile.active' "$CONFIG_FILE"))" || echo "removed: $key"
    ;;

  json)
    key="$(_resolve_key "${1:-}")"
    _assert_exists "$key"
    jq --arg k "$key" '.profile.subprofiles[$k]' "$CONFIG_FILE"
    ;;

  dimensions)
    key="$(_resolve_key "${1:-}")"
    _assert_exists "$key"
    jq -r --arg k "$key" '.profile.subprofiles[$k].developer | to_entries | .[] | "\(.key)=\(.value // "null")"' "$CONFIG_FILE"
    ;;

  stack)
    key="$(_resolve_key "${1:-}")"
    _assert_exists "$key"
    jq -r --arg k "$key" '
      .profile.subprofiles[$k].stack
      | to_entries
      | map(select(.key != "declared_at" and (.value | type == "array") and (.value | length > 0)))
      | .[] | "\(.key): \(.value | join(", "))"
    ' "$CONFIG_FILE"
    ;;

  calibrate)
    skill_name="${1:-}"; [ -z "$skill_name" ] && { echo "usage: fstack-profile calibrate <skill> [<key>]" >&2; exit 2; }
    key="$(_resolve_key "${2:-}")"
    _assert_exists "$key"
    pinned="$(jq -r '.profile.pinned // ""' "$CONFIG_FILE")"
    origin="$(jq -r --arg k "$key" '.profile.subprofiles[$k].origin // "manual"' "$CONFIG_FILE")"
    obs="$(jq -r --arg k "$key" '.profile.subprofiles[$k].cluster_meta.observation_count // 0' "$CONFIG_FILE")"
    suffix="$origin"
    [ -n "$pinned" ] && [ "$pinned" = "$key" ] && suffix="$suffix, pinned"
    [ "$origin" = "inferred" ] && [ "$obs" -gt 0 ] && suffix="$suffix, $obs obs"
    echo "CALIBRATION ($key, $suffix):"
    for d in $(_skill_dims "$skill_name"); do
      v="$(jq -r --arg k "$key" --arg d "$d" '.profile.subprofiles[$k].developer[$d] // empty' "$CONFIG_FILE")"
      lbl="$(_band_label "$d" "${v:-}")"
      printf "  %-20s %-6s (%s)\n" "$d" "${v:-unset}" "$lbl"
    done
    ;;

  suggest)
    # Print one-line SUGGEST when the current context's match differs from
    # active and the user hasn't pinned / disabled. Silent otherwise.
    suggest_on="$(jq -r '.profile.auto_suggest' "$CONFIG_FILE")"
    pinned="$(jq -r '.profile.pinned' "$CONFIG_FILE")"
    [ "$suggest_on" != "true" ] && exit 0
    [ "$pinned" != "null" ] && [ -n "$pinned" ] && exit 0
    active="$(jq -r '.profile.active' "$CONFIG_FILE")"
    match="$("$BIN_DIR/fstack-cluster" match 2>/dev/null)"
    [ -z "$match" ] && exit 0
    [ "$match" = "$active" ] && exit 0
    obs="$(jq -r --arg k "$match" '.profile.subprofiles[$k].cluster_meta.observation_count // 0' "$CONFIG_FILE")"
    repo="$(git rev-parse --show-toplevel 2>/dev/null | awk -F/ '{print $NF}')"
    branch="$(git branch --show-current 2>/dev/null || echo "")"
    echo "SUGGEST: $match (matches ${repo:-?}:${branch:-?}, $obs obs, current $active). switch with: fstack-profile use $match"
    ;;

  vibe)
    key="$(_resolve_key "${1:-}")"
    _assert_exists "$key"
    parts=()
    any="no"
    for d in risk_tolerance bias_for_action scope_appetite test_rigor architecture_care detail_preference autonomy; do
      v="$(jq -r --arg k "$key" --arg d "$d" '.profile.subprofiles[$k].developer[$d] // empty' "$CONFIG_FILE")"
      [ -n "$v" ] && any="yes"
      parts+=("$(_band_label "$d" "${v:-}")")
    done
    if [ "$any" = "no" ]; then
      echo "$key: unset"
      exit 0
    fi
    echo "$key: ${parts[0]} · ${parts[1]} · ${parts[2]} · ${parts[3]} · ${parts[4]} · ${parts[5]} · ${parts[6]}"
    ;;

  show|"")
    key="$(_resolve_key "${1:-}")"
    _assert_exists "$key"
    active="$(jq -r '.profile.active' "$CONFIG_FILE")"
    origin="$(jq -r --arg k "$key" '.profile.subprofiles[$k].origin // "manual"' "$CONFIG_FILE")"
    label="$(jq -r --arg k "$key" '.profile.subprofiles[$k].label // $k' "$CONFIG_FILE")"
    desc="$(jq -r --arg k "$key" '.profile.subprofiles[$k].description // ""' "$CONFIG_FILE")"
    declared="$(jq -r --arg k "$key" '.profile.subprofiles[$k].declared_at // "never"' "$CONFIG_FILE")"
    samples="$(jq -r --arg k "$key" '.profile.subprofiles[$k].inferred.sample_count // 0' "$CONFIG_FILE")"
    disc_bin="$(jq -r --arg k "$key" '.profile.subprofiles[$k].cluster_meta.discipline_bin // ""' "$CONFIG_FILE")"
    amb_bin="$(jq -r --arg k "$key" '.profile.subprofiles[$k].cluster_meta.ambition_bin // ""' "$CONFIG_FILE")"

    if [ "$key" = "$active" ]; then
      echo "ARCHETYPE: $key ($origin, active)"
    else
      echo "ARCHETYPE: $key ($origin)"
    fi
    [ "$key" != "$label" ] && echo "  label: $label"
    if [ -n "$disc_bin" ] && [ -n "$amb_bin" ]; then
      echo "  $disc_bin x $amb_bin"
    fi
    [ -n "$desc" ] && [ "$origin" = "manual" ] && echo "  $desc"
    echo ""
    echo "DIMENSIONS"
    for d in risk_tolerance bias_for_action scope_appetite test_rigor architecture_care detail_preference autonomy; do
      v="$(jq -r --arg k "$key" --arg d "$d" '.profile.subprofiles[$k].developer[$d] // empty' "$CONFIG_FILE")"
      lbl="$(_band_label "$d" "${v:-}")"
      printf "  %-20s %-6s (%s)\n" "$d:" "${v:-unset}" "$lbl"
    done

    if [ "$origin" = "inferred" ]; then
      echo ""
      echo "SEEN IN"
      jq -r --arg k "$key" '
        .profile.subprofiles[$k].context_distribution
        | to_entries
        | sort_by(-.value)
        | .[0:5]
        | .[]
        | "  \(.key)  (\(.value))"
      ' "$CONFIG_FILE"
      echo ""
      echo "EXAMPLES"
      jq -r --arg k "$key" '.profile.subprofiles[$k].examples[]? | "  - \(.)"' "$CONFIG_FILE"
    fi

    echo ""
    echo "PREFERENCES"
    jq -r --arg k "$key" '.profile.subprofiles[$k].preferences | to_entries | .[] | "  \(.key): \(.value // "unset")"' "$CONFIG_FILE"
    echo ""
    echo "STACK"
    "$0" stack "$key" | sed 's/^/  /' || true
    echo ""
    echo "Declared: $declared"
    echo "Observations: $samples"
    ;;

  *)
    echo "fstack-profile: unknown command '$cmd'" >&2
    exit 2
    ;;
esac
